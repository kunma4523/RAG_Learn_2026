# RAG-Learning 环境配置
# 请复制此文件为 .env 并填入您的实际配置

# ============================================
# LLM (大语言模型) 配置
# ============================================

# LLM 提供商: openai / anthropic / google / qwen / local
LLM_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic 配置
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Google (Gemini) 配置
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-1.5-flash

# 阿里云 Qwen 配置
DASHSCOPE_API_KEY=your-dashscope-api-key-here
QWEN_MODEL=qwen-turbo

# 本地模型配置 (如需使用本地模型)
LOCAL_LLM_MODEL=Qwen/Qwen2-7B-Instruct
LOCAL_LLM_DEVICE=cpu

# LLM 默认参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TOP_P=0.9

# ============================================
# Embedding (文本嵌入) 配置
# ============================================

# Embedding 提供商: openai / local / dashscope
EMBEDDING_PROVIDER=openai

# OpenAI Embedding
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 阿里云 DashScope Embedding
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# 本地 Embedding 模型
LOCAL_EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
LOCAL_EMBEDDING_DEVICE=cpu

# Embedding 默认参数
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TOP_K=5

# ============================================
# 其他配置
# ============================================

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
